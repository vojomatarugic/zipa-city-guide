# Supabase Edge Function bundle (no trailing slash). Overrides bundled project default.
# Full URL (recommended for clarity):
# VITE_API_BASE=https://YOUR_PROJECT_REF.supabase.co/functions/v1/make-server-a0e1e9cb
#
# Path-only (resolved with project ref from src/utils/supabase/info.tsx):
# VITE_API_BASE=/functions/v1/make-server-a0e1e9cb

VITE_API_BASE=

# EmailJS (contact form) — https://www.emailjs.com/docs/sdk/installation/
# Use your EmailJS dashboard values (public key only; never commit secrets to app code).
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
